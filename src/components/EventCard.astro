---
interface Props {
  id: string;
  title: string;
  vertical: string;
  published_date: Date;
  summary: string;
  tags: string[];
  event_name: string;
  event_date: Date;
  venue_name: string;
  venue_type: 'online' | 'offline' | 'hybrid';
  organizer: string;
  registration_url: string;
  fee?: string;
}

const {
  id,
  title,
  vertical,
  event_date,
  summary,
  tags,
  venue_name,
  venue_type,
  organizer,
  registration_url,
  fee,
} = Astro.props;

const formattedEventDate = event_date.toLocaleDateString('ja-JP', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
  weekday: 'short',
});

const venueTypeLabel = {
  online: 'オンライン',
  offline: 'オフライン',
  hybrid: 'ハイブリッド',
}[venue_type];
---

<article class="event-card">
  <div class="event-card-meta">
    <a href={`/vertical/${vertical}`} class="vertical-tag">{vertical}</a>
    <span class={`venue-badge venue-${venue_type}`}>{venueTypeLabel}</span>
  </div>
  <h2 class="event-card-title">
    <a href={`/events/${id}`}>{title}</a>
  </h2>
  <p class="event-card-summary">{summary}</p>
  <div class="event-info">
    <div class="event-info-item">
      <span class="event-info-label">日時</span>
      <time datetime={event_date.toISOString()}>{formattedEventDate}</time>
    </div>
    <div class="event-info-item">
      <span class="event-info-label">会場</span>
      <span>{venue_name}</span>
    </div>
    <div class="event-info-item">
      <span class="event-info-label">主催</span>
      <span>{organizer}</span>
    </div>
    {fee && (
      <div class="event-info-item">
        <span class="event-info-label">参加費</span>
        <span>{fee}</span>
      </div>
    )}
  </div>
  <div class="event-card-footer">
    {tags.length > 0 && (
      <div class="card-tags">
        {tags.map((tag) => (
          <span class="tag">#{tag}</span>
        ))}
      </div>
    )}
    <a href={registration_url} target="_blank" rel="noopener noreferrer" class="register-btn">
      申し込む
    </a>
  </div>
</article>

<style>
  .event-card {
    background: var(--color-card-bg);
    border: 1px solid var(--color-border);
    border-radius: 6px;
    padding: 1.25rem;
    transition: box-shadow 0.2s;
  }

  .event-card:hover {
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
  }

  .event-card-meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.5rem;
    font-size: 0.8rem;
  }

  .vertical-tag {
    background: var(--color-tag-bg);
    color: #fff;
    padding: 0.1rem 0.4rem;
    border-radius: 3px;
    font-size: 0.7rem;
    font-weight: 600;
  }

  .vertical-tag:hover {
    text-decoration: none;
    opacity: 0.85;
  }

  .venue-badge {
    padding: 0.1rem 0.4rem;
    border-radius: 3px;
    font-size: 0.7rem;
    font-weight: 600;
  }

  .venue-online {
    background: #e8f5e9;
    color: #2e7d32;
  }

  .venue-offline {
    background: #e3f2fd;
    color: #1565c0;
  }

  .venue-hybrid {
    background: #fff3e0;
    color: #e65100;
  }

  .event-card-title {
    font-size: 1.1rem;
    line-height: 1.5;
    margin-bottom: 0.5rem;
  }

  .event-card-title a {
    color: var(--color-text);
  }

  .event-card-title a:hover {
    color: var(--color-accent);
    text-decoration: none;
  }

  .event-card-summary {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    line-height: 1.6;
    margin-bottom: 0.75rem;
  }

  .event-info {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.35rem 1rem;
    font-size: 0.8rem;
    margin-bottom: 0.75rem;
    padding: 0.75rem;
    background: var(--color-bg);
    border-radius: 4px;
  }

  .event-info-item {
    display: flex;
    gap: 0.4rem;
  }

  .event-info-label {
    color: var(--color-text-muted);
    white-space: nowrap;
  }

  .event-card-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
  }

  .card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .tag {
    font-size: 0.7rem;
    color: var(--color-accent);
  }

  .register-btn {
    display: inline-block;
    padding: 0.35rem 0.85rem;
    background: var(--color-accent);
    color: #fff;
    border-radius: 4px;
    font-size: 0.8rem;
    font-weight: 600;
    white-space: nowrap;
  }

  .register-btn:hover {
    background: var(--color-accent-hover);
    text-decoration: none;
    color: #fff;
  }
</style>
