---
interface Props {
  id: string;
  title: string;
  vertical: string;
  published_date: Date;
  summary: string;
  tags: string[];
  source_name?: string;
}

const { id, title, vertical, published_date, summary, tags, source_name } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');

const formattedDate = published_date.toLocaleDateString('ja-JP', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<article class="card">
  <div class="card-meta">
    <a href={`${base}vertical/${vertical}`} class="vertical-tag">{vertical}</a>
    <time datetime={published_date.toISOString()}>{formattedDate}</time>
    {source_name && <span class="source-badge">{source_name}</span>}
  </div>
  <h2 class="card-title">
    <a href={`${base}articles/${id}`}>{title}</a>
  </h2>
  <p class="card-summary">{summary}</p>
  {tags.length > 0 && (
    <div class="card-tags">
      {tags.map((tag) => (
        <span class="tag">#{tag}</span>
      ))}
    </div>
  )}
</article>

<style>
  .card {
    background: var(--color-card-bg);
    border: 1px solid var(--color-border);
    border-radius: 6px;
    padding: 1.25rem;
    transition: box-shadow 0.2s;
  }

  .card:hover {
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
  }

  .card-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.5rem;
    font-size: 0.8rem;
    color: var(--color-text-muted);
  }

  .vertical-tag {
    background: var(--color-tag-bg);
    color: #fff;
    padding: 0.1rem 0.4rem;
    border-radius: 3px;
    font-size: 0.7rem;
    font-weight: 600;
  }

  .vertical-tag:hover {
    text-decoration: none;
    opacity: 0.85;
  }

  .source-badge {
    background: var(--color-border);
    color: var(--color-text-muted);
    padding: 0.1rem 0.4rem;
    border-radius: 3px;
    font-size: 0.65rem;
  }

  .card-title {
    font-size: 1.1rem;
    line-height: 1.5;
    margin-bottom: 0.5rem;
  }

  .card-title a {
    color: var(--color-text);
  }

  .card-title a:hover {
    color: var(--color-accent);
    text-decoration: none;
  }

  .card-summary {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    line-height: 1.6;
    margin-bottom: 0.5rem;
  }

  .card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .tag {
    font-size: 0.7rem;
    color: var(--color-accent);
  }
</style>
