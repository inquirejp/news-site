---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import ArticleCard from '../components/ArticleCard.astro';
import EventCard from '../components/EventCard.astro';
import CurationCard from '../components/CurationCard.astro';

const allArticles = await getCollection('articles', ({ data }) => {
  return data.status === 'published' || data.status === 'approved';
});

const articles = allArticles.sort(
  (a, b) => b.data.published_date.getTime() - a.data.published_date.getTime()
);

const now = new Date();
const upcomingEvents = (await getCollection('events', ({ data }) => {
  return (data.status === 'published' || data.status === 'approved') && data.event_date >= now;
}))
  .sort((a, b) => a.data.event_date.getTime() - b.data.event_date.getTime())
  .slice(0, 3);

const latestCurations = (await getCollection('curations', ({ data }) => {
  return data.status === 'published' || data.status === 'approved';
}))
  .sort((a, b) => b.data.published_date.getTime() - a.data.published_date.getTime())
  .slice(0, 5);

// 全コンテンツからタグを集計
const tagCounts = new Map<string, number>();
[...allArticles, ...await getCollection('events'), ...await getCollection('curations')].forEach((item) => {
  if (item.data.tags) {
    item.data.tags.forEach((tag: string) => {
      tagCounts.set(tag, (tagCounts.get(tag) || 0) + 1);
    });
  }
});
const sortedTags = [...tagCounts.entries()].sort((a, b) => b[1] - a[1]);
const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');
---

<BaseLayout title="トップ" description="最新ニュースをお届けします">
  <section class="hero">
    <h1>最新ニュース</h1>
    <p>特定テーマの最新動向をAIが半自動的にキュレーション</p>
  </section>

  <nav class="section-nav">
    <a href="#news" class="active">ニュース</a>
    <a href="#events">イベント</a>
    <a href="#curations">キュレーション</a>
  </nav>

  <section id="news" class="section-block first">
    <div class="section-header">
      <h2>ニュース</h2>
      <a href={base} class="view-all">すべて見る →</a>
    </div>
    <div class="grid">
      {articles.map((article) => (
        <ArticleCard
          id={article.id}
          title={article.data.title}
          vertical={article.data.vertical}
          published_date={article.data.published_date}
          summary={article.data.summary}
          tags={article.data.tags}
        />
      ))}
    </div>
    {articles.length === 0 && (
      <p class="empty-state">まだ記事がありません。</p>
    )}
  </section>

  <section id="events" class="section-block">
    <div class="section-header">
      <h2>イベント</h2>
      <a href={`${base}events/`} class="view-all">すべて見る →</a>
    </div>
    {upcomingEvents.length > 0 ? (
      <div class="grid">
        {upcomingEvents.map((event) => (
          <EventCard
            id={event.id}
            title={event.data.title}
            vertical={event.data.vertical}
            published_date={event.data.published_date}
            summary={event.data.summary}
            tags={event.data.tags}
            event_name={event.data.event_name}
            event_date={event.data.event_date}
            venue_name={event.data.venue_name}
            venue_type={event.data.venue_type}
            organizer={event.data.organizer}
            registration_url={event.data.registration_url}
            fee={event.data.fee}
          />
        ))}
      </div>
    ) : (
      <p class="empty-state">現在予定されているイベントはありません。</p>
    )}
  </section>

  <section id="curations" class="section-block">
    <div class="section-header">
      <h2>キュレーション</h2>
      <a href={`${base}curations/`} class="view-all">すべて見る →</a>
    </div>
    {latestCurations.length > 0 ? (
      <div class="grid">
        {latestCurations.map((curation) => (
          <CurationCard
            id={curation.id}
            title={curation.data.title}
            vertical={curation.data.vertical}
            source_url={curation.data.source_url}
            source_name={curation.data.source_name}
            published_date={curation.data.published_date}
            summary={curation.data.summary}
            editorial_comment={curation.data.editorial_comment}
            tags={curation.data.tags}
          />
        ))}
      </div>
    ) : (
      <p class="empty-state">まだキュレーション記事がありません。</p>
    )}
  </section>

  {sortedTags.length > 0 && (
    <section class="section-block tags-section">
      <h2>タグ一覧</h2>
      <div class="tags-cloud">
        {sortedTags.map(([tag, count]) => (
          <a href={`${base}tag/${tag}`} class="tag-item">
            #{tag} <span class="tag-count">{count}</span>
          </a>
        ))}
      </div>
    </section>
  )}
</BaseLayout>

<style>
  .hero {
    margin-bottom: 1.5rem;
  }

  .hero h1 {
    font-size: 1.5rem;
    margin-bottom: 0.25rem;
  }

  .hero p {
    color: var(--color-text-muted);
    font-size: 0.9rem;
  }

  .section-nav {
    display: flex;
    gap: 0.5rem;
    margin-bottom: 2rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--color-border);
  }

  .section-nav a {
    font-size: 0.85rem;
    padding: 0.3rem 0.75rem;
    border: 1px solid var(--color-border);
    border-radius: 20px;
    color: var(--color-text-muted);
  }

  .section-nav a:hover,
  .section-nav a.active {
    background: var(--color-accent);
    color: #fff;
    border-color: var(--color-accent);
    text-decoration: none;
  }

  .section-block {
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 2px solid var(--color-border);
  }

  .section-block.first {
    margin-top: 0;
    padding-top: 0;
    border-top: none;
  }

  .section-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1.25rem;
  }

  .section-header h2 {
    font-size: 1.25rem;
  }

  .view-all {
    font-size: 0.85rem;
    color: var(--color-accent);
  }

  .grid {
    display: grid;
    gap: 1rem;
  }

  .empty-state {
    text-align: center;
    color: var(--color-text-muted);
    padding: 2rem 0;
  }

  .tags-section h2 {
    font-size: 1.25rem;
    margin-bottom: 1.25rem;
  }

  .tags-cloud {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .tag-item {
    font-size: 0.85rem;
    padding: 0.3rem 0.6rem;
    border: 1px solid var(--color-border);
    border-radius: 4px;
    color: var(--color-text);
    background: var(--color-card-bg);
    transition: all 0.15s;
  }

  .tag-item:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
    text-decoration: none;
  }

  .tag-count {
    font-size: 0.7rem;
    color: var(--color-text-muted);
    margin-left: 0.15rem;
  }
</style>
