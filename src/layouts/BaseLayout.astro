---
interface Props {
  title: string;
  description?: string;
}

const { title, description = 'AI半自動ニュースサイト' } = Astro.props;
const siteName = 'News Site'; // TODO: サイト名確定後に変更
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title} | {siteName}</title>
  </head>
  <body>
    <header class="site-header">
      <div class="container">
        <a href="/" class="site-title">{siteName}</a>
        <nav class="site-nav">
          <a href="/">ニュース</a>
          <a href="/events/">イベント</a>
          <a href="/curations/">キュレーション</a>
          <slot name="nav" />
        </nav>
      </div>
    </header>
    <main class="container">
      <slot />
    </main>
    <footer class="site-footer">
      <div class="container">
        <p>&copy; {new Date().getFullYear()} {siteName}</p>
      </div>
    </footer>
  </body>
</html>

<style is:global>
  :root {
    /* inquire.jp カラーパターン準拠 */
    --color-bg: #f8ede1;
    --color-text: #111;
    --color-text-muted: #666;
    --color-accent: #c36339;
    --color-accent-hover: #a8522e;
    --color-border: #eee;
    --color-card-bg: #fff;
    --color-header-bg: #252525;
    --color-header-text: #fff;
    --color-footer-bg: #252525;
    --color-footer-text: #fff;
    --color-tag-bg: #32373c;
    --max-width: 960px;
    --font-sans: 'Lato', 'Hiragino Kaku Gothic ProN', 'Noto Sans JP', Helvetica Neue, Roboto, Arial, sans-serif;
    --font-body: 'Ubuntu', 'Hiragino Kaku Gothic ProN', Meiryo, Helvetica Neue, Roboto, Arial, sans-serif;
  }

  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  body {
    font-family: var(--font-body);
    background: var(--color-bg);
    color: var(--color-text);
    line-height: 1.8;
    font-size: 16px;
  }

  h1, h2, h3, h4, h5 {
    font-family: var(--font-sans);
  }

  .container {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  a {
    color: var(--color-accent);
    text-decoration: none;
  }

  a:hover {
    color: var(--color-accent-hover);
    text-decoration: underline;
  }
</style>

<style>
  .site-header {
    padding: 0.875rem 0;
    background: var(--color-header-bg);
  }

  .site-header .container {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .site-title {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--color-header-text);
  }

  .site-title:hover {
    text-decoration: none;
    color: var(--color-accent);
  }

  .site-nav {
    display: flex;
    gap: 1.25rem;
  }

  .site-nav a {
    color: var(--color-header-text);
    font-size: 0.9rem;
    opacity: 0.8;
  }

  .site-nav a:hover {
    opacity: 1;
    text-decoration: none;
    color: var(--color-accent);
  }

  .site-footer {
    padding: 2rem 0;
    margin-top: 3rem;
    background: var(--color-footer-bg);
    color: var(--color-footer-text);
    font-size: 0.875rem;
  }

  main {
    padding: 2rem 0;
  }
</style>
